<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane styleClass="main-container"
            stylesheets="@../../css/styles.css"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.dankotyt.core.controller.network.DevicesController">

    <top>
        <BorderPane styleClass="encrypt-top-container">
            <left>
                <HBox style="-fx-padding: 20 0 0 20;">
                    <Button fx:id="backButton" styleClass="icon-back-button" />
                </HBox>
            </left>
            <center>
                <VBox alignment="CENTER" style="-fx-padding: 80 0 0 0;">
                    <Label styleClass="title" text="Доступные устройства" />
                    <Region prefWidth="100" />
                </VBox>
            </center>
            <right>
                <HBox style="-fx-padding: 20 20 0 0;">
                    <Button fx:id="refreshButton" styleClass="refresh-button" text="Обновить" />
                </HBox>
            </right>
        </BorderPane>
    </top>

    <center>
        <VBox alignment="TOP_CENTER" spacing="20" styleClass="encrypt-center-container" VBox.vgrow="ALWAYS">

            <!-- Добавляем информацию о текущем устройстве -->
            <Label fx:id="currentDeviceLabel" styleClass="current-device-label" />

            <!-- Поле для ручного ввода IP -->
            <HBox alignment="CENTER" spacing="10" style="-fx-padding: 0 0 10 0;">
                <TextField fx:id="manualIpField" promptText="Введите IP адрес"
                           styleClass="manual-ip-field" prefWidth="200"/>
                <Button fx:id="manualConnectButton" text="Подключиться"
                        styleClass="manual-connect-button"
                        onAction="#handleManualConnection"/>
            </HBox>

            <ScrollPane fitToWidth="true" styleClass="devices-scroll-pane" VBox.vgrow="ALWAYS">
                <VBox fx:id="devicesContainer" alignment="CENTER" spacing="15" styleClass="devices-container" />
            </ScrollPane>

            <StackPane fx:id="noDevicesPane" styleClass="no-devices-container" >
                <Label prefHeight="37.0" prefWidth="185.0" styleClass="no-devices-label" text="Устройства не найдены" />
            </StackPane>
        </VBox>
    </center>

    <bottom>
        <VBox alignment="CENTER" spacing="10" style="-fx-padding: 0 0 20 0;">
            <Label fx:id="statusLabel" styleClass="status-label" text="Статус: Ожидание" />
            <Region styleClass="space-in-bottom" />
        </VBox>
    </bottom>
</BorderPane>