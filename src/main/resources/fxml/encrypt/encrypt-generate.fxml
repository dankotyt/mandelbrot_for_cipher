<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane styleClass="main-container" stylesheets="@../../css/styles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.dankotyt.core.controller.encrypt.EncryptGenerateController">

    <top>
        <BorderPane styleClass="encrypt-generate-top-container">
            <left>
                <HBox style="-fx-padding: 20 0 0 20;">
                    <Button fx:id="backButton" styleClass="icon-back-button" />
                </HBox>
            </left>
            <center>
                <VBox alignment="CENTER" style="-fx-padding: 80 0 0 0;">
                    <Label styleClass="encrypt-generate-title" text="Ваше изображение-ключ:" />
                    <Region prefHeight="100" />
                </VBox>
            </center>
        </BorderPane>
    </top>

    <center>
        <GridPane styleClass="encrypt-generate-grid">
            <columnConstraints>
            <ColumnConstraints hgrow="NEVER" minWidth="10.0" prefWidth="50.0" />
                <ColumnConstraints hgrow="NEVER" prefWidth="450.0" />
                <ColumnConstraints hgrow="NEVER" prefWidth="150.0" />
                <ColumnConstraints hgrow="ALWAYS" />
                <ColumnConstraints hgrow="NEVER" prefWidth="100" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints vgrow="ALWAYS" />
            </rowConstraints>

            <VBox spacing="30" styleClass="hint-console-container" GridPane.columnIndex="1">
                <StackPane fx:id="hintBoxContainer" VBox.vgrow="NEVER" />
                <TextArea fx:id="console" prefHeight="135.0" prefWidth="450.0" styleClass="generate-console" GridPane.columnIndex="1" />
            </VBox>

            <VBox alignment="CENTER" spacing="15" styleClass="encrypt-generate-content" GridPane.columnIndex="3" GridPane.rowIndex="0">
                <StackPane fx:id="imageContainer" styleClass="image-container">
                    <ImageView fx:id="imageView" fitHeight="480" fitWidth="640" translateX="150" />
                    <Region styleClass="dark-gray-rect-without-translate" />
                    <StackPane fx:id="loadingContainer" styleClass="loading-container">
                        <Label styleClass="loading-label" text="Картинка генерируется..." />
                    </StackPane>
                </StackPane>
                <HBox alignment="CENTER" spacing="10" styleClass="encrypt-generate-buttons">
                    <Button fx:id="regenerateButton" styleClass="icon-repeat-button" />
                    <Button fx:id="manualButton" styleClass="icon-write-params-button" />
                    <Button fx:id="okayButton" styleClass="icon-next-button" />
                    <Button fx:id="swapButton" styleClass="icon-swap-button" />
                </HBox>
            </VBox>

        </GridPane>
    </center>
</BorderPane>
